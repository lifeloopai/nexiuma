<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }}</title>
  <style>
    :root { --primary: #0f172a; --accent: #3b82f6; --muted: #64748b; --bg: #f1f5f9; }
    body { font-family: Inter, system-ui, sans-serif; margin: 0; background: var(--bg); color: #1e293b; }
    .header { background: linear-gradient(135deg, #0f172a, #1e3a5f); color: white; padding: 2rem; }
    .container { max-width: 1200px; margin: 0 auto; padding: 2rem; }
    .highlight { background: #eff6ff; border-left: 4px solid var(--accent); padding: 1rem 1.25rem; border-radius: 0 8px 8px 0; margin-bottom: 1.5rem; }
    table { width: 100%; border-collapse: collapse; background: white; border-radius: 10px; overflow: hidden; margin: 1.5rem 0; }
    th, td { padding: 0.75rem 1rem; text-align: left; border-bottom: 1px solid #e2e8f0; }
    th { background: #f8fafc; }
    iframe { width: 100%; height: 460px; border: none; border-radius: 10px; background: white; }
    .section h2 { border-bottom: 2px solid var(--accent); padding-bottom: 0.5rem; }
  </style>
</head>
<body>
  <div class="header">
    <h1>{{ title }}</h1>
    <p>{{ subtitle }} · Generated {{ generated_at }}</p>
  </div>
  <div class="container">
    <div class="highlight">
      <strong>Best parameters (Sharpe):</strong> {{ best_params }}
      — Sharpe {{ best_sharpe }}, Return {{ best_return }}
    </div>
    <div class="section">
      <h2>Grid Results</h2>
      <table>
        <tr>{% for h in headers %}<th>{{ h }}</th>{% endfor %}</tr>
        {% for row in rows %}
        <tr>{% for cell in row %}<td>{{ cell }}</td>{% endfor %}</tr>
        {% endfor %}
      </table>
    </div>
    <div class="section">
      <h2>Heatmaps</h2>
      <iframe src="{{ heatmap_path }}" title="Optimization heatmaps"></iframe>
    </div>
  </div>
</body>
</html>
