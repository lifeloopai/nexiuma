# Nexiuma Configuration
# Copy to .env and adjust values

# Market data
TICKER=AAPL
START_DATE=2020-01-01
END_DATE=2024-12-31
AUTO_REFRESH=false

# Strategy
STRATEGY=moving_average
FAST_PERIOD=20
SLOW_PERIOD=50

# Capital & risk
INITIAL_CAPITAL=100000
POSITION_SIZE_PCT=0.95
STOP_LOSS_PCT=0.05
TAKE_PROFIT_PCT=0.15
MAX_POSITION_SIZE_PCT=1.0

# Paths
DATA_CACHE_DIR=data/cache
BACKTEST_RESULTS_DIR=backtests/results
REPORTS_DIR=reports/output
LOGS_DIR=logs

# Backtest
COMMISSION_PCT=0.001
SLIPPAGE_PCT=0.0005
RISK_FREE_RATE=0.04
USE_VOLATILITY_SIZING=false
TARGET_VOLATILITY=0.15
